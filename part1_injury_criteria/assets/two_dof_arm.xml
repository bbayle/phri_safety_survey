<!-- Part 1: two_dof_arm.xml
     A planar 2-DOF manipulator (shoulder + elbow) whose end-effector
     can contact a compliant foam pad representing a human body region.
     Gravity is in -Z (planar motion in XZ plane).
-->
<mujoco model="two_dof_arm">
  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.8 0.8 0.8"/>
  </visual>

  <asset>
    <material name="robot_mat"  rgba="0.2 0.5 0.8 1"/>
    <material name="pad_mat"    rgba="0.8 0.3 0.3 0.5"/>
    <material name="floor_mat"  rgba="0.7 0.7 0.7 1"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" type="plane" size="2 2 0.1"
          material="floor_mat" condim="3"/>

    <!-- Compliant contact pad (represents human body region — arm) -->
    <body name="contact_pad" pos="0.7 0 0.5">
      <geom name="pad" type="box" size="0.08 0.08 0.02"
            material="pad_mat" solimp="0.99 0.999 0.001" solref="0.01 1"
            condim="3" mass="0"/>
    </body>

    <!-- Robot base -->
    <body name="base" pos="0 0 0.1">
      <geom name="base_geom" type="cylinder" size="0.05 0.05"
            material="robot_mat" mass="2"/>

      <!-- Shoulder joint -->
      <body name="upper_arm" pos="0 0 0.05">
        <joint name="shoulder" type="hinge" axis="0 1 0"
               range="-1.57 1.57" damping="2.0"/>
        <geom name="upper_arm_geom" type="capsule"
              fromto="0 0 0  0.3 0 0" size="0.025"
              material="robot_mat" mass="1"/>

        <!-- Elbow joint -->
        <body name="forearm" pos="0.3 0 0">
          <joint name="elbow" type="hinge" axis="0 1 0"
                 range="-2.5 0.0" damping="1.5"/>
          <geom name="forearm_geom" type="capsule"
                fromto="0 0 0  0.3 0 0" size="0.02"
                material="robot_mat" mass="0.7"/>

          <!-- End-effector -->
          <body name="end_effector" pos="0.3 0 0">
            <geom name="end_effector" type="sphere" size="0.03"
                  material="robot_mat" mass="0.2"
                  solimp="0.99 0.999 0.001" solref="0.02 1"/>
            <site name="ee_site" size="0.01"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="shoulder_act" joint="shoulder" gear="80"  ctrllimited="true" ctrlrange="-40 40"/>
    <motor name="elbow_act"    joint="elbow"    gear="60"  ctrllimited="true" ctrlrange="-30 30"/>
  </actuator>
</mujoco>
