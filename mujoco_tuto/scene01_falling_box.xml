<mujoco model="falling_box">

  <option gravity="0 0 -9.81" timestep="0.001" integrator="RK4"/>

  <visual>
    <global azimuth="90" elevation="0"/>
    <map fogstart="3" fogend="5"/>
  </visual>

  <worldbody>

    <camera name="main" pos="0 -5 5" xyaxes="1 0 0  0 0 1" fovy="45"/>



    <geom name="floor" type="plane" size="5 5 0.1"
          rgba="0.8 0.8 0.8 1"
          solref="-10000 -100" solimp="0.8 0.99 0.001"/>

    <body name="box" pos="0 0 2">
      <freejoint/>
      <geom name="box_geom" type="box" size="0.1 0.1 0.1"
            rgba="0.2 0.6 0.9 1" mass="1"
            solref="-10000 -100" solimp="0.95 0.95 0.001"/>
    </body>

  </worldbody>

</mujoco>